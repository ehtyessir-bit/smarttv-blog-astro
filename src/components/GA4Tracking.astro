---
// src/components/GA4Tracking.astro
// Google Analytics 4 Tracking Component for blog.smarttv.one
// Automatically tracks page views and events

const GA4_ID = import.meta.env.PUBLIC_GA4_ID || "G-PLACEHOLDER";
const GA4_DEBUG = import.meta.env.PUBLIC_GA4_DEBUG === "true" || false;
---

<!-- Google Analytics 4 -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
<script define:vars={{ GA4_ID, GA4_DEBUG }}>
  window.dataLayer = window.dataLayer || [];
  
  function gtag() {
    dataLayer.push(arguments);
  }
  
  gtag("js", new Date());
  gtag("config", GA4_ID, {
    page_path: window.location.pathname,
    page_title: document.title,
    anonymize_ip: true,
    cookie_flags: "SameSite=None;Secure",
    allow_google_signals: false,
    allow_ad_personalization_signals: false,
    linker: {
      domains: ["blog.smarttv.one", "smarttv.one"],
    },
  });
  
  // Track page views
  gtag("event", "page_view", {
    page_path: window.location.pathname,
    page_title: document.title,
    page_location: window.location.href,
  });
  
  // Debug mode
  if (GA4_DEBUG) {
    console.log("GA4 Tracking enabled:", GA4_ID);
    console.log("Current page:", window.location.pathname);
  }
  
  // Track scroll depth
  let maxScroll = 0;
  window.addEventListener("scroll", () => {
    const scrollPercent = Math.round(
      (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100
    );
    
    if (scrollPercent > maxScroll) {
      maxScroll = scrollPercent;
      
      // Track at 25%, 50%, 75%, 100%
      if ([25, 50, 75, 100].includes(scrollPercent)) {
        gtag("event", "scroll", {
          scroll_depth: scrollPercent,
          page_path: window.location.pathname,
        });
        
        if (GA4_DEBUG) {
          console.log(`Scroll depth: ${scrollPercent}%`);
        }
      }
    }
  });
  
  // Track outbound links
  document.addEventListener("click", (event) => {
    const link = (event.target as HTMLElement).closest("a");
    
    if (link) {
      const href = link.getAttribute("href");
      
      // Check if it's an external link
      if (href && !href.startsWith("/") && !href.startsWith("#")) {
        gtag("event", "click_link", {
          link_url: href,
          link_text: link.textContent || "Link",
          page_path: window.location.pathname,
        });
        
        if (GA4_DEBUG) {
          console.log("Outbound click tracked:", href);
        }
      }
    }
  });
  
  // Track form submissions
  document.addEventListener("submit", (event) => {
    const form = event.target as HTMLFormElement;
    
    if (form) {
      gtag("event", "form_submit", {
        form_name: form.getAttribute("name") || "unknown",
        page_path: window.location.pathname,
      });
      
      if (GA4_DEBUG) {
        console.log("Form submitted:", form.getAttribute("name"));
      }
    }
  });
</script>
