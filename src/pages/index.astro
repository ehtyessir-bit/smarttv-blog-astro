---
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
const SITE = 'https://smarttv.one';
const WHATSAPP = 'https://wa.me/447311127035';
const WA_SVG = `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L0 24l6.337-1.507A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.795 9.795 0 01-4.994-1.366l-.358-.213-3.76.894.942-3.656-.234-.376A9.77 9.77 0 012.182 12C2.182 6.578 6.578 2.182 12 2.182S21.818 6.578 21.818 12 17.422 21.818 12 21.818z"/></svg>`;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>SmartTV.one — IPTV Anleitungen &amp; Nachrichten</title>
  <meta name="description" content="Setup-Tutorials, Anbieter-Vergleiche und alles, was Sie über IPTV wissen müssen. WM 2026 live schauen — Deutschland, Österreich, Schweiz."/>
  <link rel="canonical" href="https://blog.smarttv.one/"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#f7f7f8;color:#111}
    a{color:inherit;text-decoration:none}
    .hd{background:#fff;border-bottom:1px solid #e5e7eb;position:sticky;top:0;z-index:100}
    .hd-in{max-width:1100px;margin:0 auto;padding:0 20px;height:64px;display:flex;align-items:center;justify-content:space-between}
    .logo{font-size:20px;font-weight:900;color:#111;letter-spacing:-.5px}
    .logo span{color:#7c3aed}
    .btn-h{background:#7c3aed;color:#fff;font-weight:700;font-size:14px;padding:10px 22px;border-radius:10px;transition:.2s}
    .btn-h:hover{background:#6d28d9}
    /* HERO */
    .hero{background:#fff;padding:64px 20px 56px;text-align:center;border-bottom:1px solid #e5e7eb}
    .hero h1{font-size:clamp(30px,5vw,52px);font-weight:900;color:#111;line-height:1.15;margin-bottom:16px}
    .hero h1 span{color:#7c3aed}
    .hero p{font-size:18px;color:#6b7280;max-width:520px;margin:0 auto 32px;line-height:1.6}
    .btn-row{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
    .btn-pur{display:inline-block;background:#7c3aed;color:#fff;font-weight:700;font-size:15px;padding:13px 28px;border-radius:11px;transition:.2s}
    .btn-pur:hover{background:#6d28d9}
    .btn-wa{display:inline-flex;align-items:center;gap:8px;background:#25d366;color:#fff;font-weight:700;font-size:14px;padding:12px 22px;border-radius:11px;transition:.2s}
    .btn-wa:hover{background:#1ebe5d}
    /* PREMIUM BANNER */

    /* ARTICLES */
    .section{max-width:1100px;margin:0 auto;padding:40px 20px}
    .section-title{font-size:22px;font-weight:800;color:#111;margin-bottom:24px}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
    .card{background:#fff;border-radius:16px;border:1px solid #e5e7eb;overflow:hidden;transition:.15s;display:flex;flex-direction:column}
    .card:hover{border-color:#7c3aed;box-shadow:0 4px 20px rgba(124,58,237,.1);transform:translateY(-2px)}
    .card-img{width:100%;height:180px;object-fit:cover;display:block}
    .card-body{padding:20px;flex:1;display:flex;flex-direction:column}
    .card-tag{display:inline-block;background:#ede9fe;color:#7c3aed;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:3px 10px;border-radius:20px;margin-bottom:10px}
    .card h3{font-size:16px;font-weight:700;color:#111;margin-bottom:8px;line-height:1.35;flex:1}
    .card p{font-size:13px;color:#888;line-height:1.55;margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .card-foot{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:#aaa;margin-top:auto}
    .card-read{color:#7c3aed;font-weight:600;font-size:13px}
    /* BOTTOM CTA */
    .bot{background:#fff;border-top:1px solid #e5e7eb;padding:60px 20px;text-align:center}
    .bot h2{font-size:28px;font-weight:900;color:#111;margin-bottom:8px}
    .bot p{font-size:15px;color:#888;margin-bottom:28px}
    /* FLOAT WA */
    .wa-fl{position:fixed;bottom:24px;right:24px;z-index:999;background:#25d366;color:#fff;width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.45);transition:.2s}
    .wa-fl:hover{transform:scale(1.1)}
    .wa-fl svg{width:28px;height:28px;fill:#fff}
    .ft{border-top:1px solid #e5e7eb;padding:24px 20px;text-align:center;font-size:13px;color:#888}
    .ft a{color:#7c3aed}
  </style>
</head>
<body>

<!-- HEADER -->
<header class="hd">
  <div class="hd-in">
    <a href="/" class="logo">Smart<span>TV</span>.one</a>
    <a href={SITE} target="_blank" rel="noopener" class="btn-h">IPTV Abonnement</a>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <h1>IPTV <span>Anleitungen</span> &amp; Nachrichten</h1>
  <p>Setup-Tutorials, Anbieter-Vergleiche und alles, was Sie über IPTV wissen müssen</p>
  <div class="btn-row">
    <a href={SITE} target="_blank" rel="noopener" class="btn-pur">IPTV Abonnement holen &rarr;</a>
    <a href={WHATSAPP} target="_blank" rel="noopener" class="btn-wa">
      <Fragment set:html={WA_SVG}/>
      WhatsApp Kontakt
    </a>
  </div>
</section>

<!-- ARTICLES GRID -->
<section class="section">
  <div class="section-title">Neueste Artikel</div>
  <div class="grid">
    {posts.map((post, i) => (
      <a href={`/blog/${post.slug}/`} class="card">
        <img
          class="card-img"
          src={`https://images.unsplash.com/photo-1593784991095-a205069470b6?w=600&q=70&auto=format&fit=crop&sig=${i}`}
          alt={post.data.title}
          loading="lazy"
          width="600" height="180"
        />
        <div class="card-body">
          <span class="card-tag">IPTV Guide</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <div class="card-foot">
            <time>{new Date(post.data.date).toLocaleDateString('de-DE', {year:'numeric',month:'short',day:'numeric'})}</time>
            <span class="card-read">Weiterlesen &rarr;</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- BOTTOM CTA -->
<section class="bot">
  <h2>Bereit zum Streamen?</h2>
  <p>Tausende zufriedene Kunden weltweit</p>
  <div class="btn-row">
    <a href={SITE} target="_blank" rel="noopener" class="btn-pur" style="font-size:16px;padding:15px 36px">
      IPTV Holen &mdash; &euro;15/Monat
    </a>
    <a href={WHATSAPP} target="_blank" rel="noopener" class="btn-wa" style="font-size:15px;padding:13px 24px">
      <Fragment set:html={WA_SVG}/>
      Auf WhatsApp bestellen
    </a>
  </div>
</section>

<!-- FOOTER -->
<footer class="ft">
  <p>&copy; 2026 <a href={SITE} target="_blank" rel="noopener">SmartTV.one</a> &mdash; Alle Rechte vorbehalten</p>
</footer>

<!-- FLOATING WA -->
    <a href={WHATSAPP} target="_blank" rel="noopener" class="wa-fl" title="WhatsApp Support">
