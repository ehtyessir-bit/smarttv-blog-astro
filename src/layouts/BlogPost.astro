---
interface Props {
  title: string;
  description: string;
  date: string;
  keywords?: string;
  mainSite?: string;
  slug?: string;
}

const {
  title,
  description,
  date,
  keywords,
  mainSite = 'https://smarttv.one',
  slug = '',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const dateFormatted = new Date(date).toLocaleDateString('de-DE', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "dateModified": date,
  "author": {"@type": "Organization", "name": "SmartTV Redaktion"},
  "publisher": {
    "@type": "Organization",
    "name": "SmartTV Blog",
    "url": "https://blog.smarttv.one"
  },
  "mainEntityOfPage": canonicalURL.toString()
});
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | SmartTV Blog</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="SmartTV Blog" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={schema} />
</head>
<body class="bg-gray-50 text-gray-900 font-sans">

  <header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-blue-600">SmartTV Blog</a>
      <a href={mainSite} target="_blank" rel="noopener"
         class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700 transition">
        Zu smarttv.one &rarr;
      </a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-10">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-blue-600">Blog</a>
      <span class="mx-2">&rsaquo;</span>
      <span class="text-gray-700">{title}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3 leading-tight">{title}</h1>
      <div class="flex items-center gap-3 text-sm text-gray-500">
        <time datetime={date}>{dateFormatted}</time>
        <span>&bull;</span>
        <span>SmartTV Redaktion</span>
        <span>&bull;</span>
        <a href={mainSite} class="text-blue-600 hover:underline">smarttv.one</a>
      </div>
    </header>

    <article class="prose prose-lg prose-blue max-w-none
      prose-headings:font-bold prose-headings:text-gray-900
      prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
      prose-blockquote:border-l-4 prose-blockquote:border-blue-500
      prose-blockquote:bg-blue-50 prose-blockquote:rounded-r-lg
      prose-blockquote:py-1 prose-blockquote:not-italic
      prose-strong:text-gray-900
      prose-table:text-sm prose-th:bg-gray-100 prose-td:align-middle">
      <slot />
    </article>

    <!-- Bottom CTA -->
    <div class="mt-16 rounded-2xl overflow-hidden border border-purple-500/20"
         style="background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);">
      <div class="p-8 text-center">
        <p class="text-purple-300 text-xs font-semibold uppercase tracking-widest mb-2">PREMIUM IPTV SERVICE</p>
        <h2 class="text-2xl font-bold text-white mb-2">
          Streame 220.000+ Filme &amp; 30.000+ Live-Sender
        </h2>
        <p class="text-purple-200 mb-6 text-sm">
          HD &amp; 4K &bull; Alle Ger&auml;te &bull; 24/7 Support &bull; Deutschland, &Ouml;sterreich, Schweiz
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6 text-center">
          <div class="bg-white/10 rounded-xl p-3">
            <p class="text-purple-300 text-xs">1 Monat</p>
            <p class="text-white text-xl font-bold">&euro;15</p>
            <p class="text-purple-400 text-xs">&euro;15/Mo.</p>
          </div>
          <div class="bg-white/10 rounded-xl p-3">
            <p class="text-purple-300 text-xs">3 Monate</p>
            <p class="text-white text-xl font-bold">&euro;35</p>
            <p class="text-purple-400 text-xs">&euro;11,67/Mo.</p>
          </div>
          <div class="bg-white/10 rounded-xl p-3">
            <p class="text-purple-300 text-xs">6 Monate</p>
            <p class="text-white text-xl font-bold">&euro;41</p>
            <p class="text-purple-400 text-xs">&euro;6,83/Mo.</p>
          </div>
          <div class="bg-white/10 rounded-xl p-3 border border-green-400/40">
            <p class="text-green-400 text-xs font-bold">BESTE WAHL</p>
            <p class="text-purple-300 text-xs">1 Jahr</p>
            <p class="text-white text-xl font-bold">&euro;58</p>
            <p class="text-purple-400 text-xs">&euro;4,83/Mo. +1 Gratis</p>
          </div>
        </div>
        <a href={mainSite} target="_blank" rel="noopener"
           class="inline-block bg-purple-500 hover:bg-purple-400 text-white font-bold px-10 py-4 rounded-xl text-lg transition">
          Jetzt Starten auf smarttv.one &rarr;
        </a>
        <p class="text-purple-400 text-xs mt-3">
          Mastercard &bull; VISA &bull; Apple Pay &bull; Google Pay &bull; Bitcoin
        </p>
      </div>
    </div>

  </main>

  <footer class="border-t border-gray-200 mt-12 py-8 text-center text-sm text-gray-500">
    <p>SmartTV Blog &mdash; <a href={mainSite} class="text-blue-600 hover:underline">smarttv.one</a></p>
    <p class="mt-1">Deutschland &bull; &Ouml;sterreich &bull; Schweiz</p>
  </footer>

</body>
</html>
