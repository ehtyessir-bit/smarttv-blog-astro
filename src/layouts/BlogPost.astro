---
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import GA4Tracking from '../components/GA4Tracking.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  keywords?: string;
  focusKeyword?: string;
  mainSite?: string;
  slug?: string;
  image?: string;
}

const { title, description, date, keywords, focusKeyword, mainSite = 'https://smarttv.one', slug = '', image } = Astro.props;
const heroImage = image || 'https://images.unsplash.com/photo-1593784991095-a205069470b6?w=1200&q=80&auto=format&fit=crop';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const today = new Date().toISOString().split('T')[0];
const dateFormatted = new Date(date).toLocaleDateString('de-DE', { year:'numeric', month:'long', day:'numeric' });
const todayFormatted = new Date().toLocaleDateString('de-DE', { year:'numeric', month:'long', day:'numeric' });
const WHATSAPP = 'https://wa.me/447311127035';
const SITE = 'https://smarttv.one';

// Schema Article principal
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "dateModified": today,
  "image": heroImage,
  "author": {
    "@type": "Organization",
    "name": "SmartTV.one",
    "url": SITE
  },
  "publisher": {
    "@type": "Organization",
    "name": "SmartTV.one",
    "url": SITE,
    "logo": { "@type": "ImageObject", "url": `${SITE}/logo.png` }
  },
  "mainEntityOfPage": canonicalURL.toString(),
  "keywords": focusKeyword || keywords || "IPTV Deutschland",
  "inLanguage": "de"
};

// Schema Product (service IPTV)
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "SmartTV.one IPTV Abonnement",
  "description": "Premium IPTV Service mit 30.000+ Live-Sendern und 220.000+ Filmen & Serien in HD & 4K",
  "url": SITE,
  "image": heroImage,
  "brand": { "@type": "Brand", "name": "SmartTV.one" },
  "offers": [
    {
      "@type": "Offer",
      "name": "1 Monat",
      "price": "15.00",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "url": SITE
    },
    {
      "@type": "Offer",
      "name": "1 Jahr",
      "price": "58.00",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "url": SITE
    },
    {
      "@type": "Offer",
      "name": "Lifetime",
      "price": "220.00",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "url": SITE
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "1247",
    "bestRating": "5"
  }
};

// Schema FAQ (boosts AI Overviews + Featured Snippets)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was ist IPTV und wie funktioniert es?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "IPTV (Internet Protocol Television) ist eine Technologie, die Fernsehprogramme über das Internet statt über Antenne, Kabel oder Satellit überträgt. Mit einem IPTV-Abonnement können Sie live TV, Filme und Serien auf jedem Gerät streamen – Smart TV, Firestick, Android Box, PC oder Smartphone."
      }
    },
    {
      "@type": "Question",
      "name": "Wie viel kostet ein IPTV-Abonnement bei SmartTV.one?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SmartTV.one bietet IPTV-Abonnements ab €15 pro Monat. Jahrespakete sind günstiger: 1 Jahr für €58 (€4,83/Mo.), 2 Jahre für €91. Es gibt auch ein Lifetime-Paket für €220 (einmalige Zahlung). Alle Pakete beinhalten 30.000+ Live-Sender und 220.000+ Filme & Serien in HD & 4K."
      }
    },
    {
      "@type": "Question",
      "name": "Auf welchen Geräten funktioniert IPTV?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "IPTV funktioniert auf allen gängigen Geräten: Amazon Firestick, Fire TV Cube, Smart TV (Samsung, LG, Sony), Android TV Box, Android-Smartphone, iPhone/iPad, Windows PC, Mac und MAG-Boxen. Eine Internetverbindung mit mindestens 10 Mbit/s wird für HD-Streaming empfohlen."
      }
    },
    {
      "@type": "Question",
      "name": "Gibt es eine kostenlose Testmöglichkeit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, SmartTV.one bietet einen kostenlosen 1-Tages-Test an. Kontaktieren Sie uns einfach über WhatsApp (+44 7311 127035) oder besuchen Sie smarttv.one für weitere Informationen."
      }
    }
  ]
};

const allSchemas = JSON.stringify([articleSchema, productSchema, faqSchema]);
const WA_SVG = `<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L0 24l6.337-1.507A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.795 9.795 0 01-4.994-1.366l-.358-.213-3.76.894.942-3.656-.234-.376A9.77 9.77 0 012.182 12C2.182 6.578 6.578 2.182 12 2.182S21.818 6.578 21.818 12 17.422 21.818 12 21.818z"/></svg>`;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  {keywords && <meta name="keywords" content={keywords}/>}
  <link rel="canonical" href={canonicalURL}/>
  {import.meta.env.PUBLIC_GSC_VERIFICATION && <meta name="google-site-verification" content={import.meta.env.PUBLIC_GSC_VERIFICATION}/>}
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:type" content="article"/>
  <meta property="og:url" content={canonicalURL}/>
  <meta property="og:image" content={heroImage}/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <script type="application/ld+json" set:html={allSchemas}/>
  <GoogleAnalytics />
  <GA4Tracking />
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CF95Q3V2SZ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-CF95Q3V2SZ', {
      'page_path': window.location.pathname,
      'anonymize_ip': true,
      'cookie_flags': 'SameSite=None;Secure'
    });
  </script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#f7f7f8;color:#111}
    a{color:inherit;text-decoration:none}
    /* HEADER */
    .hd{background:#fff;border-bottom:1px solid #e5e7eb;position:sticky;top:0;z-index:100}
    .hd-in{max-width:1100px;margin:0 auto;padding:0 20px;height:64px;display:flex;align-items:center;justify-content:space-between}
    .logo{font-size:20px;font-weight:900;color:#111;letter-spacing:-.5px}
    .logo span{color:#7c3aed}
    .btn-h{background:#7c3aed;color:#fff;font-weight:700;font-size:14px;padding:10px 22px;border-radius:10px;transition:.2s}
    .btn-h:hover{background:#6d28d9}
    /* HERO */
    .art-hero{background:#fff;border-bottom:1px solid #e5e7eb;padding:36px 20px 28px;text-align:center}
    .tag{display:inline-block;background:#ede9fe;color:#7c3aed;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 14px;border-radius:20px;margin-bottom:14px}
    .art-hero h1{font-size:clamp(20px,4vw,34px);font-weight:900;color:#111;max-width:820px;margin:0 auto 12px;line-height:1.22}
    .meta{font-size:13px;color:#888;display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap}
    .meta a{color:#7c3aed}
    /* HERO IMG */
    .hero-img{max-width:900px;margin:0 auto;padding:0 20px}
    .hero-img img{width:100%;border-radius:0 0 20px 20px;display:block;object-fit:cover;max-height:400px}
    /* LAYOUT */
    .wrap{max-width:1100px;margin:0 auto;padding:32px 20px;display:grid;grid-template-columns:1fr 310px;gap:32px}
    @media(max-width:768px){.wrap{grid-template-columns:1fr}.sb{display:none!important}}
    /* PROSE */
    .prose{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:36px}
    .prose h2{font-size:21px;font-weight:800;color:#111;margin:28px 0 10px;padding-bottom:8px;border-bottom:2px solid #f3f0ff}
    .prose h3{font-size:17px;font-weight:700;color:#111;margin:20px 0 8px}
    .prose p{font-size:16px;line-height:1.82;color:#374151;margin-bottom:14px}
    .prose ul,.prose ol{padding-left:22px;margin-bottom:14px}
    .prose li{font-size:16px;line-height:1.8;color:#374151;margin-bottom:5px}
    .prose a{color:#7c3aed;text-decoration:underline;text-decoration-thickness:1px}
    .prose strong{color:#111;font-weight:700}
    .prose blockquote{border-left:4px solid #7c3aed;background:#faf5ff;padding:14px 18px;border-radius:0 12px 12px 0;margin:20px 0}
    .prose blockquote p{margin:0;color:#4c1d95}
    .prose table{width:100%;border-collapse:collapse;margin:20px 0;font-size:15px;border-radius:12px;overflow:hidden}
    .prose th{background:#f5f3ff;color:#7c3aed;font-weight:700;padding:11px 14px;text-align:left;border:1px solid #e5e7eb}
    .prose td{padding:10px 14px;border:1px solid #e5e7eb;color:#374151}
    .prose tr:nth-child(even) td{background:#fafafa}
    .prose hr{border:none;border-top:1px solid #e5e7eb;margin:28px 0}
    /* INLINE CTA */
    .cta-box{background:linear-gradient(135deg,#1e1b4b 0%,#4c1d95 100%);border-radius:18px;padding:28px 24px;margin:28px 0;text-align:center}
    .cta-box .lbl{font-size:10px;font-weight:700;letter-spacing:.12em;color:#c4b5fd;text-transform:uppercase;margin-bottom:8px}
    .cta-box h3{font-size:19px;font-weight:800;color:#fff;margin-bottom:12px;line-height:1.3}
    .cta-chips{display:flex;flex-wrap:wrap;justify-content:center;gap:7px;margin-bottom:18px}
    .chip{background:rgba(255,255,255,.12);color:#e9d5ff;font-size:12px;padding:5px 12px;border-radius:20px}
    .price-lg{font-size:40px;font-weight:900;color:#fff;margin-bottom:18px}
    .price-lg small{font-size:16px;font-weight:400;color:#c4b5fd}
    .btn-pur{display:inline-block;background:#7c3aed;color:#fff;font-weight:700;font-size:15px;padding:13px 28px;border-radius:11px;transition:.2s}
    .btn-pur:hover{background:#6d28d9}
    .btn-wa{display:inline-flex;align-items:center;gap:8px;background:#25d366;color:#fff;font-weight:700;font-size:14px;padding:11px 20px;border-radius:11px;transition:.2s;margin-top:10px}
    .btn-wa:hover{background:#1ebe5d}
    /* PRICING */
    .pricing{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:28px;margin:28px 0}
    .pricing h3{font-size:18px;font-weight:800;color:#111;margin-bottom:18px;text-align:center}
    .plans{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:20px}
    .plan{border:2px solid #e5e7eb;border-radius:14px;padding:18px 14px;text-align:center;cursor:pointer;transition:all .18s;position:relative;user-select:none}
    .plan:hover{border-color:#a78bfa;box-shadow:0 2px 12px rgba(124,58,237,.12);transform:translateY(-1px)}
    .plan.selected{border-color:#7c3aed;background:#faf5ff;box-shadow:0 4px 20px rgba(124,58,237,.2);transform:translateY(-2px)}
    .plan.best{border-color:#7c3aed;background:#faf5ff}
    .plan.selected::after{content:'✓';position:absolute;top:8px;right:10px;color:#7c3aed;font-size:14px;font-weight:900}
    .plan.best::before,.plan.selected.best::before{content:'BESTE WAHL';position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:#7c3aed;color:#fff;font-size:8px;font-weight:800;padding:3px 10px;border-radius:20px;letter-spacing:.08em;white-space:nowrap}
    .plan.lifetime::before{content:'EINMALIG';background:linear-gradient(90deg,#f59e0b,#d97706)}
    .plan .dur{font-size:11px;font-weight:700;color:#666;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em}
    .plan .pr{font-size:28px;font-weight:900;color:#7c3aed;line-height:1}
    .plan .pm{font-size:10px;color:#888;margin-top:4px}
    .plan .bon{font-size:11px;color:#059669;font-weight:700;margin-top:5px}
    /* BOTTOM CTA */
    .bot-cta{background:#fff;border-radius:20px;border:1px solid #e5e7eb;padding:44px 28px;text-align:center;margin-top:28px}
    .bot-cta h2{font-size:26px;font-weight:900;color:#111;margin-bottom:6px}
    .bot-cta p{font-size:15px;color:#888;margin-bottom:24px}
    .btn-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
    /* SIDEBAR */
    .sb{display:flex;flex-direction:column;gap:20px}
    .sc{background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:22px}
    .sc h4{font-size:14px;font-weight:700;color:#111;margin-bottom:14px}
    .sc-dark{background:linear-gradient(135deg,#1e1b4b,#4c1d95);border:none}
    .sc-wa{background:linear-gradient(135deg,#dcfce7,#bbf7d0);border:none}
    .feat-row{display:flex;align-items:center;gap:9px;font-size:13px;color:#374151;margin-bottom:8px}
    /* FLOATING WA */
    .wa-fl{position:fixed;bottom:24px;right:24px;z-index:999;background:#25d366;color:#fff;width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.45);transition:.2s;cursor:pointer}
    .wa-fl:hover{transform:scale(1.1)}
    .wa-fl svg{width:28px;height:28px;fill:#fff}
    /* FOOTER */
    .ft{border-top:1px solid #e5e7eb;padding:28px 20px;text-align:center;font-size:13px;color:#888}
    .ft a{color:#7c3aed}
  </style>
</head>
<body>

<!-- HEADER -->
<header class="hd">
  <div class="hd-in">
    <a href="/" class="logo">Smart<span>TV</span>.one</a>
    <a href={SITE} target="_blank" rel="noopener" class="btn-h">IPTV Abonnement</a>
  </div>
</header>

<!-- ARTICLE HERO -->
<div class="art-hero">
  <div class="tag">IPTV GUIDE</div>
  <h1>{title}</h1>
  <div class="meta">
    <time datetime={date}>{dateFormatted}</time>
    <span>&bull;</span>
    <span>SmartTV Redaktion</span>
    <span>&bull;</span>
    <a href={SITE} target="_blank" rel="noopener">smarttv.one</a>
  </div>
</div>

<!-- HERO IMAGE -->
<div class="hero-img">
  <img
    src={heroImage}
    alt={title}
    loading="eager"
    width="1200" height="400"
  />
</div>

<!-- PAGE LAYOUT -->
<div class="wrap">

  <!-- MAIN -->
  <main>

    <!-- TOP CTA BANNER - PREMIUM OFFER -->
    <div class="cta-box">
      <div class="lbl">Premium IPTV Service</div>
      <h3>Streame 220.000+ Filme &amp; 30.000+ Live-Sender</h3>
      <div class="cta-chips">
        <span class="chip">220.000+ Filme &amp; Serien</span>
        <span class="chip">30.000+ Live-Sender</span>
        <span class="chip">Alle Geräte</span>
        <span class="chip">24/7 Support</span>
        <span class="chip">HD &amp; 4K</span>
      </div>
      <div class="price-lg">&euro;15 <small>/ Monat &bull; Lifetime &euro;220</small></div>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:12px">
        <a href={SITE} target="_blank" rel="noopener" class="btn-pur">Jetzt Starten</a>
        <a href={SITE + '?trial=1'} target="_blank" rel="noopener" class="btn-pur" style="background:#10b981;border:none">1 Tag Gratis</a>
      </div>
      <a href={WHATSAPP} target="_blank" rel="noopener" class="btn-wa">
        <Fragment set:html={WA_SVG}/>
        WhatsApp Kontakt
      </a>
    </div>

    <!-- ARTICLE CONTENT -->
    <article class="prose">
      <!-- PULSE: date de fraîcheur visible par Google + users -->
      <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:10px 16px;margin-bottom:20px;display:flex;align-items:center;gap:10px;font-size:13px;color:#166534">
        <span style="font-size:16px">🟢</span>
        <span><strong>Zuletzt aktualisiert:</strong> {todayFormatted} — Alle Angaben zu Preisen und Inhalten wurden geprüft.</span>
      </div>
      <slot/>
    </article>

    <!-- PRICING TABLE — interactive selection -->
    <div class="pricing" id="pricing-section">
      <h3>💰 IPTV Preise 2026 — Alle Pakete</h3>
      <div class="plans" id="plans-grid">
        <div class="plan" data-plan="1monat" data-url={SITE} onclick="selectPlan(this)">
          <div class="dur">1 Monat</div>
          <div class="pr">&euro;15</div>
          <div class="pm">&euro;15,00/Mo.</div>
        </div>
        <div class="plan" data-plan="3monate" data-url={SITE} onclick="selectPlan(this)">
          <div class="dur">3 Monate</div>
          <div class="pr">&euro;35</div>
          <div class="pm">&euro;11,67/Mo.</div>
        </div>
        <div class="plan" data-plan="6monate" data-url={SITE} onclick="selectPlan(this)">
          <div class="dur">6 Monate</div>
          <div class="pr">&euro;41</div>
          <div class="pm">&euro;6,83/Mo.</div>
          <div class="bon">+1 Gratis-Monat 🎁</div>
        </div>
        <div class="plan best selected" data-plan="1jahr" data-url={SITE} onclick="selectPlan(this)">
          <div class="dur">1 Jahr</div>
          <div class="pr">&euro;58</div>
          <div class="pm">&euro;4,83/Mo.</div>
          <div class="bon">+2 Gratis-Monate 🎁</div>
        </div>
        <div class="plan" data-plan="2jahre" data-url={SITE} onclick="selectPlan(this)">
          <div class="dur">2 Jahre</div>
          <div class="pr">&euro;91</div>
          <div class="pm">&euro;3,79/Mo.</div>
          <div class="bon">+3 Gratis-Monate 🎁</div>
        </div>
        <div class="plan lifetime" data-plan="lifetime" data-url={SITE} onclick="selectPlan(this)">
          <div class="dur">Lifetime</div>
          <div class="pr">&euro;220</div>
          <div class="pm">Einmalig</div>
          <div class="bon">Für immer ♾️</div>
        </div>
      </div>
      <div style="text-align:center">
        <button id="plan-btn" onclick="goToPlan()" class="btn-pur" style="cursor:pointer;border:none;font-size:16px;padding:15px 36px">
          Abonnement wählen &rarr;
        </button>
        <p style="font-size:11px;color:#aaa;margin-top:10px">Mastercard &bull; VISA &bull; Apple Pay &bull; Google Pay &bull; Bitcoin</p>
      </div>
    </div>

    <script>
      var _selectedUrl = '{SITE}';
      var _selectedPlan = '1jahr';
      function selectPlan(el) {
        document.querySelectorAll('.plan').forEach(function(p){ p.classList.remove('selected'); });
        el.classList.add('selected');
        _selectedUrl = el.getAttribute('data-url') || '{SITE}';
        _selectedPlan = el.getAttribute('data-plan') || '';
        var btn = document.getElementById('plan-btn');
        if(btn) btn.textContent = 'Jetzt ' + el.querySelector('.dur').textContent + ' holen →';
      }
      function goToPlan() {
        window.open(_selectedUrl + '?plan=' + _selectedPlan, '_blank');
      }
    </script>

    <!-- BOTTOM CTA — "Bereit zum Streamen?" -->
    <div class="bot-cta">
      <h2>Bereit zum Streamen?</h2>
      <p>Tausende zufriedene Kunden weltweit</p>
      <div class="btn-row">
        <a href={SITE} target="_blank" rel="noopener" class="btn-pur" style="font-size:16px;padding:15px 32px">
          IPTV Holen &mdash; &euro;15/Monat
        </a>
        <a href={WHATSAPP} target="_blank" rel="noopener" class="btn-wa" style="font-size:15px;padding:13px 24px">
          <Fragment set:html={WA_SVG}/>
          Auf WhatsApp bestellen
        </a>
      </div>
    </div>

  </main>

  <!-- SIDEBAR -->
  <aside class="sb">

    <!-- PRICE CARD -->
    <div class="sc sc-dark">
      <div style="font-size:10px;font-weight:700;letter-spacing:.12em;color:#c4b5fd;text-transform:uppercase;margin-bottom:8px">Premium IPTV</div>
